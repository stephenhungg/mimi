{
	"compilerOptions": {
		"target": "ES2022",
		"module": "nodenext",
		"outDir": "./dist",
		"rootDir": "./",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"moduleResolution": "nodenext",
		"lib": ["ES2022", "DOM"]
	},
	"include": [
		"mimi-events/**/*.ts",
		"mimi-github-bridge/**/*.ts",
		"mimi-overnight-pulse/**/*.ts",
		"mimi-thumbnail-render/**/*.ts",
		"mimi-mcp-server/**/*.ts",
		"mimi-notion-agents/**/*.ts",
		"_shared/**/*.ts"
	],
	"exclude": ["node_modules", "dist", ".examples"]
}
