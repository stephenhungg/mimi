# mimi. environment — copy to .env.local and fill in.
# never commit .env or .env.local (in .gitignore).

# ─── notion (workspace + dbs) ────────────────────────────────────────────────
NOTION_TOKEN=secret_xxx
NOTION_PARENT_PAGE_ID=
# filled in by scripts/provision-notion-dbs.ts after first run:
NOTION_DB_RESIDENTS=
NOTION_DB_EVENTS=
NOTION_DB_ARTIFACTS=
NOTION_DB_CONVERSATIONS=
NOTION_DB_AGENT_MEMORY=

# ─── livekit (multiplayer presence + chat data channel) ─────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# the one room everyone joins for the shared workspace (v1: single room).
LIVEKIT_ROOM=mimi-house-main

# ─── anthropic (agent runtime brain) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── github (webhook bridge) ────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=
GITHUB_REPO=owner/repo

# ─── workers (deployed via ntn) ─────────────────────────────────────────────
MIMI_EVENTS_URL=https://mimi-events.example.workers.dev
MIMI_THUMBNAIL_URL=https://mimi-thumbnail-render.example.workers.dev
MIMI_GITHUB_BRIDGE_URL=https://mimi-github-bridge.example.workers.dev

# ─── public (exposed to apps/web via vite) ──────────────────────────────────
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
VITE_TOKEN_ENDPOINT=http://localhost:3000/api/livekit-token
VITE_THUMBNAIL_URL=https://mimi-thumbnail-render.example.workers.dev
